# --- Option A: Same Wi‑Fi (expo start --lan) ---
# EXPO_PUBLIC_API_URL=http://YOUR_MAC_IP:5001

# --- Option B: Expo tunnel + ngrok (recommended when not on same Wi‑Fi) ---
# 1. Add NGROK_AUTHTOKEN to narang-backend/.env
# 2. Run: cd narang-backend && npm run dev:tunnel
# 3. Backend writes .env.local automatically — restart Expo with --clear
# Or paste the ngrok URL from the backend log:
# EXPO_PUBLIC_API_URL=https://xxxx.ngrok-free.app

EXPO_PUBLIC_API_URL=http://192.168.100.19:5001
