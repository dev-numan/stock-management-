# Neon: use POOLED url for the app (host contains "-pooler")
# Pool/timeouts are also set in src/config/db.js if not present in the URL
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pool_timeout=120&connect_timeout=30&connection_limit=5
# Neon: use DIRECT url for migrations only (Prisma migrate)
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=your_super_secret_key_here
PORT=5001
NODE_ENV=development

# Expo tunnel / remote phone testing (npm run dev:tunnel)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
