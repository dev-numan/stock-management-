# Railway Postgres (local dev): Postgres service → Variables → DATABASE_PUBLIC_URL
# Public proxy example: zephyr.proxy.rlwy.net:50534 (use full URL from dashboard, not host alone)
DATABASE_URL=postgresql://postgres:password@zephyr.proxy.rlwy.net:50534/railway?sslmode=require
DIRECT_URL=postgresql://postgres:password@zephyr.proxy.rlwy.net:50534/railway?sslmode=require

# Neon (optional): pooled url for app, direct url for migrations
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=your_super_secret_key_here
PORT=5001
NODE_ENV=development

# Expo tunnel / remote phone testing (npm run dev:tunnel)
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
