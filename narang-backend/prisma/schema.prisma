generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CASHIER
}

enum Unit {
  KG
  BAG
  LITRE
  PIECE
  BOTTLE
}

enum PaymentMethod {
  CASH
  CREDIT
}

enum PartyType {
  CUSTOMER
  SUPPLIER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CASHIER)
  createdAt DateTime @default(now())
  sales     Sale[]
}

model Settings {
  id                 Int     @id @default(1)
  shopName           String  @default("Hafeez Zarai Markaz")
  address            String  @default("Main Bazar, Punjab, Pakistan")
  phone              String  @default("")
  taxPercent         Decimal @default(0)
  invoicePrefix      String  @default("HZM")
  showLowStockAlert  Boolean @default(true)
  showExpiryAlert    Boolean @default(true)
  expiryAlertMonths  Int     @default(3)
}

model Party {
  id             String              @id @default(uuid())
  name           String
  phone          String?
  address        String?
  partyType      PartyType           @default(CUSTOMER)
  advanceBalance Decimal             @default(0)
  createdAt      DateTime            @default(now())
  sales          Sale[]
  advanceEntries PartyAdvanceEntry[]
  purchases      Purchase[]
  payments       PartyPayment[]
  products       Product[]
}

model PartyPayment {
  id        String   @id @default(uuid())
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  amount    Decimal
  notes     String?
  createdAt DateTime @default(now())

  @@index([partyId])
}

model PartyAdvanceEntry {
  id        String   @id @default(uuid())
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  saleId    String?
  sale      Sale?    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  amount    Decimal
  notes     String?
  createdAt DateTime @default(now())

  @@index([partyId])
}

model Product {
  id                  String         @id @default(uuid())
  name                String
  category            String
  unit                Unit           @default(BAG)
  alternateSaleUnit   Unit?
  unitsPerStockUnit   Decimal?
  costPrice           Decimal
  salePrice           Decimal
  currentStock        Decimal        @default(0)
  minStockAlert       Decimal        @default(10)
  expiryDate          DateTime?
  partyId             String?
  party               Party?         @relation(fields: [partyId], references: [id])
  createdAt           DateTime       @default(now())
  saleItems           SaleItem[]
  purchaseItems       PurchaseItem[]
}

model Sale {
  id                 String                @id @default(uuid())
  clientRequestId    String?               @unique
  invoiceNumber      String                @unique
  partyId            String?
  party              Party?                @relation(fields: [partyId], references: [id])
  subtotal           Decimal
  taxPercent         Decimal               @default(0)
  taxAmount          Decimal               @default(0)
  discount           Decimal               @default(0)
  totalAmount        Decimal
  paymentMethod      PaymentMethod         @default(CASH)
  promiseReturnDate  DateTime?
  notes              String?
  createdById        String
  createdBy          User                  @relation(fields: [createdById], references: [id])
  createdAt          DateTime              @default(now())
  items              SaleItem[]
  advanceEntries     PartyAdvanceEntry[]
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  soldUnit  Unit
  quantity  Decimal
  unitPrice Decimal
  total     Decimal
}

model Purchase {
  id          String         @id @default(uuid())
  partyId     String?
  party       Party?         @relation(fields: [partyId], references: [id])
  totalAmount Decimal
  notes       String?
  createdAt   DateTime       @default(now())
  items       PurchaseItem[]
}

model PurchaseItem {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Decimal
  costPrice  Decimal
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  amount    Decimal
  category  String
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
}
